{
  "sourceLanguage": "en",
  "strings": {
    "%lld pages left": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "残り%lldページ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还剩 %lld 页"
          }
        }
      }
    },
    "%lld%%": {
      "shouldTranslate": false
    },
    "%lld%% - p.%lld/%lld": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld%% - p.%2$lld/%3$lld"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld%% %2$lld/%3$lldp"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld%% %2$lld/%3$lld页"
          }
        }
      }
    },
    "+1": {
      "shouldTranslate": false
    },
    "+10": {
      "shouldTranslate": false
    },
    "+5": {
      "shouldTranslate": false
    },
    "Add books on iPhone or iPad": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneまたはiPadで本を追加"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 iPhone 或 iPad 上添加书籍"
          }
        }
      }
    },
    "Books": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブック"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "书架"
          }
        }
      }
    },
    "No Books": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本がありません"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有书籍"
          }
        }
      }
    },
    "Page %lld of %lld": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld / %2$lldページ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "第 %1$lld 页 / 共 %2$lld 页"
          }
        }
      }
    },
    "Please restart the app or check your iCloud settings.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを再起動するか、iCloud の設定を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请重启应用或检查您的 iCloud 设置。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
